{
  "name": "clinicconnect",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --config user-interface/vite.config.ts",
    "build": "vite build --config user-interface/vite.config.ts",
    "preview": "vite preview --config user-interface/vite.config.ts",
    "server:user": "tsx watch user-backend/index.ts",
    "server:admin": "tsx watch admin-backend/index.ts",
    "server": "concurrently \"npm run server:user\" \"npm run server:admin\"",
    "dev:all": "concurrently \"npm run dev\" \"npm run server\"",
    "admin:create": "node admin-backend/create-demo-admin.js",
    "setup:demo": "npm run admin:create"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "html2canvas": "^1.4.1",
    "mongodb": "^7.0.0",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^8.2.2",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
